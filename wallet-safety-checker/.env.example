# ── Client-side (bundled into browser JS — use VITE_ prefix) ─────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
VITE_GOPLUS_ACCESS_TOKEN=
VITE_ALCHEMY_API_KEY=

# Admin API secret: pass this as the x-admin-secret header when calling /api/seeds.
# The VITE_ copy is embedded in the client bundle so the admin UI can auto-authenticate.
# Use a long random string (e.g. openssl rand -hex 32).
VITE_ADMIN_API_SECRET=

# ── Server-side Supabase (Vercel env vars — no VITE_ prefix, never in bundle) ─
# In Vercel, set at least SUPABASE_URL + SUPABASE_ANON_KEY (or SERVICE_ROLE_KEY).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=

# Admin secret (server-side mirror of VITE_ADMIN_API_SECRET — validated on GET/DELETE /api/seeds).
ADMIN_API_SECRET=

# ── GoPlus (server-side only) ─────────────────────────────────────────────────
GOPLUS_ACCESS_TOKEN=

# ── Resend (server-side only) ─────────────────────────────────────────────────
# Get your key from https://resend.com/api-keys
# RESEND_FROM_EMAIL must be a verified sender domain in Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=support@one-key.link

# ── Optional: restrict API CORS to your production domain ────────────────────
# Leave blank (or omit) to allow * (open). Set to your domain, e.g. https://one-key.link
APP_ORIGIN=
