VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
VITE_GOPLUS_ACCESS_TOKEN=
VITE_ALCHEMY_API_KEY=

# Server-side Supabase vars (used by /api/seeds, /api/record-seed, /api/record-wallet)
# In Vercel, set at least SUPABASE_URL + SUPABASE_ANON_KEY.
# Prefer SUPABASE_SERVICE_ROLE_KEY for server writes.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=

# Server-side only (Vercel Functions — no VITE_ prefix needed)
# Used by /api/goplus.ts to authenticate GoPlus server-side calls.
# Set this in Vercel project settings → Environment Variables.
GOPLUS_ACCESS_TOKEN=

# ── Resend (server-side only — used by /api/send-email) ─────────────────
# Get your key from https://resend.com/api-keys and verify your sending
# domain. RESEND_FROM_EMAIL must use a domain you have verified in Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=support@one-key.link
